+    setAs400(localStorage.getItem("as400") === "1");
+  }, []);
+  useEffect(() => {
+    document.documentElement.classList.toggle("as400", as400);
+    localStorage.setItem("as400", as400 ? "1" : "0");
+  }, [as400]);
+  return { as400, toggle: () => setAs400((v) => !v) };
